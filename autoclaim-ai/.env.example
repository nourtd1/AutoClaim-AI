# Anthropic API key — get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=your_key_here

# Path to the SQLite database file (relative to project root)
DATABASE_PATH=./autoclaim.db

# Public app metadata (available client-side)
NEXT_PUBLIC_APP_NAME=AutoClaim AI
NEXT_PUBLIC_HACKATHON=UiPath AgentHack 2026

# ── UiPath Maestro (optional — local simulation works without these) ──────────
# Get these from Automation Cloud after publishing the AutoClaimAI BPMN process
UIPATH_BASE_URL=https://cloud.uipath.com/YOUR_ORG/YOUR_TENANT
UIPATH_PAT_TOKEN=your_personal_access_token_here
UIPATH_FOLDER_NAME=Default
UIPATH_PROCESS_KEY=AutoClaimAI
UIPATH_API_TRIGGER_URL=https://cloud.uipath.com/YOUR_ORG/YOUR_TENANT/orchestrator_/t/YOUR_TRIGGER_SLUG
